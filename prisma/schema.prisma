generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ai_analysis {
  id            Int      @id @default(autoincrement())
  paridade      Int?
  matches       String[] @db.VarChar(100)
  weaknesses    String[] @db.VarChar(200)
  justificativa String?
  summary       String?  @db.VarChar(200)
  requisitos    String[]
  vagas         vagas[]
}

model descricoes {
  descricao String?
  id        Int     @id @default(autoincrement())
  vagas     vagas[]
}

model vagas {
  id              Int          @id @default(autoincrement())
  titulo          String?      @db.VarChar(200)
  empresa         String?      @db.VarChar(200)
  cidade          String?      @db.VarChar(200)
  link            String?      @db.VarChar(200)
  dt_publicacao   DateTime?    @db.Date
  area            String?      @db.VarChar(100)
  salario         String?      @db.VarChar(12)
  plataforma      String?      @db.VarChar(20)
  jobid           String?      @db.VarChar(50)
  modalidade      String?      @db.VarChar(10)
  dt_register     DateTime?    @default(now()) @db.Date
  descricao_fk    Int?
  acesso          String?      @default("salvo") @db.VarChar(20)
  disponibilidade Boolean?     @default(true)
  ai_analysis_fk  Int?
  keywords        String[]     @db.VarChar(200)
  searchwords     String[]     @db.VarChar(100)
  ai_analysis     ai_analysis? @relation(fields: [ai_analysis_fk], references: [id], onDelete: NoAction, onUpdate: NoAction)
  descricoes      descricoes?  @relation(fields: [descricao_fk], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
