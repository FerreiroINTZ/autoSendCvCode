generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ai_analysis {
  id            Int      @default(autoincrement())
  paridade      Int?
  macthes       String[] @db.VarChar(50)
  weaknesses    String[] @db.VarChar(100)
  justificativa String?  @db.VarChar(200)
  summary       String?  @db.VarChar(100)

  @@ignore
}

model descricoes {
  descricao  String?
  id         Int      @id @default(autoincrement())
  requisitos String[] @db.VarChar(50) // analisado pela ai
  vagas      vagas[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model teste {
  id  Int     @default(autoincrement())
  msg String?
  slw Int?

  @@ignore
}

model vagas {
  id              Int         @id @default(autoincrement())
  titulo          String?     @db.VarChar(100)
  empresa         String?     @db.VarChar(100)
  cidade          String?     @db.VarChar(100)
  link            String?     @db.VarChar(200)
  dt_publicacao   DateTime?   @db.Date
  keywords        String?     @db.VarChar(200)
  area            String?     @db.VarChar(50)
  salario         String?     @db.VarChar(12)
  plataforma      String?     @db.VarChar(20)
  jobid           String?     @db.VarChar(50)
  modalidade      String?     @db.VarChar(10)
  dt_register     DateTime?   @default(now()) @db.Date
  justificativa   String?
  paridade        Int?
  requisitos      String[]    @db.VarChar(200)
  descricao_fk    Int?
  acesso          String?     @default("salvo") @db.VarChar(20)
  disponibilidade Boolean?    @default(true)
  descricoes      descricoes? @relation(fields: [descricao_fk], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
